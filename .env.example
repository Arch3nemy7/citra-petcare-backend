# ============================================================================
# Citra PetCare API — environment configuration
# Copy to .env for local development. Every variable marked (required) must be
# set or the server refuses to boot and prints the full list of problems.
# ============================================================================

# --- application ---
# development | production
APP_ENV=development
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
# json | pretty  (use pretty for local dev, json in production)
LOG_FORMAT=pretty
# standard tracing filter, e.g. info,citra_petcare=debug,sqlx=warn
RUST_LOG=info,citra_petcare=debug,tower_http=info,sqlx=warn

# --- database (required) ---
DATABASE_URL=postgres://petcare:petcare@127.0.0.1:5433/petcare
DATABASE_MAX_CONNECTIONS=10
# apply pending migrations automatically when the server starts
AUTO_MIGRATE=true

# --- auth (required) ---
# minimum 32 characters; generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-hex-string-please-really-do-it
ACCESS_TOKEN_TTL_SECS=900
REFRESH_TOKEN_TTL_DAYS=30

# --- HTTP hardening ---
# comma-separated list of allowed browser origins (Flutter web / dev tools)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
RATE_LIMIT_ENABLED=true
# per-IP limits default to 25 req/s with a burst of 100 (a screen of pet
# photos resolves many presigned URLs at once). Only set these to override —
# a pinned value here silently wins over raised defaults in later releases.
#RATE_LIMIT_PER_SECOND=25
#RATE_LIMIT_BURST=100
REQUEST_TIMEOUT_SECS=30
BODY_LIMIT_BYTES=2097152

# --- file storage ---
# local | s3
STORAGE_DRIVER=local
# root directory for the local driver
STORAGE_LOCAL_ROOT=./storage-data
# how long presigned upload/download URLs stay valid
PRESIGN_TTL_SECS=900
# Base URL the local driver mints presigned URLs against. Set it to the
# address CLIENTS reach the API on, or photo uploads fail with unreachable
# URLs: http://10.0.2.2:8080 for the Android emulator, your LAN IP for a
# physical phone, https://be-petcare.holo.my.id in production.
# Defaults to http://localhost:$HTTP_PORT when unset.
#PUBLIC_BASE_URL=http://10.0.2.2:8080

# S3 driver — OCI Object Storage S3 Compatibility API.
# Endpoint format: https://{namespace}.compat.objectstorage.{region}.oraclecloud.com
# Credentials are OCI "Customer Secret Keys" (Identity → Users → Customer Secret Keys).
#S3_ENDPOINT=https://axaxaxaxaxax.compat.objectstorage.ap-singapore-1.oraclecloud.com
#S3_REGION=ap-singapore-1
#S3_BUCKET=petcare-files
#S3_ACCESS_KEY_ID=
#S3_SECRET_ACCESS_KEY=

# --- notifications ---
# log | fcm
NOTIFIER_DRIVER=log
# FCM driver: path to the Firebase service-account JSON and the topic to send to
#FCM_SERVICE_ACCOUNT_PATH=/etc/citra/firebase-service-account.json
#FCM_TOPIC=clinic

# --- scheduler (daily reminders, 07:00 Asia/Jakarta) ---
SCHEDULER_ENABLED=true
