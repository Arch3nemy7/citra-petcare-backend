{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT m.item_id, i.name AS item_name, i.unit, m.qty\n        FROM stock_movements m\n        JOIN inventory_items i ON i.id = m.item_id\n        WHERE m.visit_id = $1 AND m.type = 'OUT' AND m.deleted_at IS NULL\n        ORDER BY m.created_at\n        ",
