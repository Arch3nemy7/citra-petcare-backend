  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, item_id, type AS \"movement_type: MovementType\", qty, reason,\n               visit_id, expiry_date, lot_no, created_at, updated_at\n        FROM stock_movements\n        WHERE item_id = $1 AND deleted_at IS NULL\n          AND ($2::uuid IS NULL OR id < $2)\n        ORDER BY id DESC\n        LIMIT $3\n        ",
