{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, name, phone, alt_phone, address, notes, created_at, updated_at\n        FROM owners\n        WHERE deleted_at IS NULL\n          AND ($1::text IS NULL OR name ILIKE '%' || $1 || '%' OR phone ILIKE '%' || $1 || '%')\n          AND ($2::uuid IS NULL OR id < $2)\n        ORDER BY id DESC\n        LIMIT $3\n        ",
