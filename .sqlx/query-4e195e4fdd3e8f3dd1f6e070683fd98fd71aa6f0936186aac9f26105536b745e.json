{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, type AS notif_type, title, body, payload, sent_at, read_at,\n               created_at, updated_at\n        FROM notifications\n        WHERE deleted_at IS NULL\n          AND (NOT $1 OR read_at IS NULL)\n          AND ($2::uuid IS NULL OR id < $2)\n        ORDER BY id DESC\n        LIMIT $3\n        ",
